<local:FlammenwerferWindowBase x:Class="FsLocalizationPlugin.Windows.CheckCompatibilityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FsLocalizationPlugin.Windows"
        xmlns:core="clr-namespace:Frosty.Core;assembly=FrostyCore"
        xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls" 
        xmlns:fdev="FrostyDeveloper"
        mc:Ignorable="d"
        UseLayoutRounding="True"
        Title="Check Compatibility - Flammenwerfer" SizeToContent="Height" MaxHeight="850" Width="400"
        >
  <!-- View model: ViewModels/ModifyStringViewModel.cs -->

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FrostyControls;component/Themes/Generic.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Background="{StaticResource WindowBackground}">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource ListBackground}"/>

    <StackPanel x:Name="MainGrid" Grid.Row="0" Margin="5, 10, 5, 10">
      <WrapPanel Orientation="Horizontal" Margin="3">
        <Label Width="Auto">
          <Label.Content>
            <StackPanel Orientation="Horizontal">
              <TextBlock Margin="0, 1, 5, 0" Text="&#xF2B7;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Language: "/>
            </StackPanel>
          </Label.Content>
        </Label>
        <ComboBox x:Name="LanguageComboBox" MinWidth="140" Width="Auto" Margin="2"
                    ItemsSource="{Binding Languages}"
                    SelectedItem="{Binding SelectedLanguage}">
        </ComboBox>
        <!-- INFO: This should include option: "All Languages" -->
      </WrapPanel>

      <!-- INFO: Show this placeholder when user cancel the refresh process and there is no data to display. -->
      <Label Margin="3" Width="Auto" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Visibility="Collapsed">
        <Label.Content>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Margin="0, 1, 5, 0" Text="&#xE946;" 
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Grid.Column="1" Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="Click Refresh to get started"/>
          </Grid>
        </Label.Content>
      </Label>
      
      <WrapPanel Orientation="Horizontal" Margin="3">
        <Label Width="Auto">
          <Label.Content>
            <StackPanel Orientation="Horizontal">
              <TextBlock Margin="0, 1, 5, 0" Text="&#xEB68;&#xEC24;"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                 RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="What will happen next?"/>
              <!-- INFO: Interesting greetings. Example:
              No strings modified yet, what will happen next?
              100 strings modified, a great start!
              1000 strings modified, amazing!
              10000 strings modified, so diligent!
              <PLACEHOLDER> strings modified, you've modified all the strings, お疲れ様でした!
              -->
            </StackPanel>
          </Label.Content>
        </Label>
      </WrapPanel>
      <Separator Margin="3, 3, 3, 0"/>
      <!-- INFO: Icon for every states. (Keep only this comment for future)
      Loading
      <ctrl:FrostySpinner Margin="0, 2, 5, 0" Width="14"/>
      Passed
      <Image Margin="0, 2, 5, 0" Width="14" Source="/FsLocalizationPlugin;component/Images/check_circle_32dp_FFFFFF_FILL1_wght600_GRAD-25_opsz24.png"
          RenderOptions.BitmapScalingMode="HighQuality"/>
      Warning
      <Image Margin="0, 2, 5, 0" Width="14" Source="/FsLocalizationPlugin;component/Images/error_32dp_FFFFFF_FILL1_wght600_GRAD-25_opsz24.png"
          RenderOptions.BitmapScalingMode="HighQuality"/>
      Error
      <Image Margin="0, 2, 5, 0" Width="14" Source="/FsLocalizationPlugin;component/Images/cancel_32dp_FFFFFF_FILL1_wght600_GRAD-25_opsz24.png"
          RenderOptions.BitmapScalingMode="HighQuality"/>
      N/A
      <Image Margin="0, 2, 5, 0" Width="14" Source="/FsLocalizationPlugin;component/Images/hide_source_32dp_FFFFFF_FILL1_wght600_GRAD-25_opsz24.png"
          RenderOptions.BitmapScalingMode="HighQuality"/>

      The N/A is used when user did not modified the select language.
      -->
      <StackPanel Margin="3">
        <Label Width="Auto">
          <Label.Content>
            <StackPanel Orientation="Horizontal">
              <ctrl:FrostySpinner Margin="0, 2, 5, 0" Width="14"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Flammenwerfer Compatibility:" FontWeight="Medium"/>
            </StackPanel>
          </Label.Content>
        </Label>
        <!-- INFO: This test is for detecting characters bigger than 0xFFFF, for example emojis. Error if found. Pass if not found. -->
        <Expander HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <StackPanel Orientation="Horizontal">
              <ctrl:FrostySpinner Margin="0, 2, 5, 0" Width="14"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Checking for unsupported characters"/>
              
              <!--<Image Margin="0, 2, 5, 0" Width="14" Source="/FsLocalizationPlugin;component/Images/cancel_32dp_FFFFFF_FILL1_wght600_GRAD-25_opsz24.png"
                        RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="2 unsupported characters"/>-->

              <!--<Image Margin="0, 2, 5, 0" Width="14" Source="/FsLocalizationPlugin;component/Images/check_circle_32dp_FFFFFF_FILL1_wght600_GRAD-25_opsz24.png"
                        RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="No unsupported characters"/>-->
            </StackPanel>
          </Expander.Header>
          <Expander.Content>
            <StackPanel>
              <TextBlock Margin="2" Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="These character(s) are bigger than 0xFFFF, not supported by Frostbite FsLocalization format."/>

              <WrapPanel Width="Auto">
                <!-- INFO: Something like ItemsRepeater for this, 1 textbox for each character. And also make it scroll-able when too much -->
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="测"
/>
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="试"
  />
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="👍"
  />
              </WrapPanel>
            </StackPanel>
          </Expander.Content>
        </Expander>
        <!-- INFO: This test is a Flammen.WriteAll test. Error if exception thrown. Pass if success. -->
        <Expander HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <StackPanel Orientation="Horizontal">
              <ctrl:FrostySpinner Margin="0, 2, 5, 0" Width="14"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Running apply test"/>
            </StackPanel>
          </Expander.Header>
          <Expander.Content>
            <StackPanel>
              <TextBlock Margin="2" Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="These character(s) are bigger than 0xFFFF, not supported by Frostbite FsLocalization format."/>

              <WrapPanel Width="Auto">
                <!-- INFO: Something like ItemsRepeater for this, 1 textbox for each character. And also make it scroll-able when too much -->
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="测"
/>
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="试"
  />
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="👍"
  />
              </WrapPanel>
            </StackPanel>
          </Expander.Content>
        </Expander>
      </StackPanel>
      <Separator Margin="3, 3, 3, 0"/>
      <StackPanel Margin="3">
        <Label Width="Auto">
          <Label.Content>
            <StackPanel Orientation="Horizontal">
              <ctrl:FrostySpinner Margin="0, 2, 5, 0" Width="14"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="FsLocalization Loader Plugin Compatibility:" FontWeight="Medium"/>
            </StackPanel>
          </Label.Content>
        </Label>
        <!-- INFO: This test is for detecting characters not in histogram, because FsLoc does not support edit histogram. Warning if found. Pass if not found. -->
        <Expander HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <StackPanel Orientation="Horizontal">
              <ctrl:FrostySpinner Margin="0, 2, 5, 0" Width="14"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Checking for characters not existing in histogram"/>
            </StackPanel>
          </Expander.Header>
          <Expander.Content>
            <StackPanel>
              <TextBlock Margin="2" Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="These character(s) does not exist in histogram. Your user need to install Flammenwerfer Plugin in order to display these characters."/>
              <WrapPanel>
                <!-- INFO: Something like ItemsRepeater for this, 1 textbox for each character. And also make it scroll-able when too much -->
                <TextBox Padding="2.5" Margin="2" Width="Auto"
   BorderThickness="1"
   AutoWordSelection="False"
   VerticalScrollBarVisibility="Disabled"
   HorizontalScrollBarVisibility="Disabled"
   IsReadOnly="True"
   Text="测"
 />
                <TextBox Padding="2.5" Margin="2" Width="Auto"
   BorderThickness="1"
   AutoWordSelection="False"
   VerticalScrollBarVisibility="Disabled"
   HorizontalScrollBarVisibility="Disabled"
   IsReadOnly="True"
   Text="试"
   />
                <TextBox Padding="2.5" Margin="2" Width="Auto"
   BorderThickness="1"
   AutoWordSelection="False"
   VerticalScrollBarVisibility="Disabled"
   HorizontalScrollBarVisibility="Disabled"
   IsReadOnly="True"
   Text="A"
   />
              </WrapPanel>
            </StackPanel>
          </Expander.Content>
        </Expander>
        <!-- INFO: This test is for detecting flammenwerfer extended features, only Remove String at this point. Warning if found. Pass if not found. -->
        <Expander HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <StackPanel Orientation="Horizontal">
              <ctrl:FrostySpinner Margin="0, 2, 5, 0" Width="14"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Checking for extended feature"/>
            </StackPanel>
          </Expander.Header>
          <Expander.Content>
            <StackPanel>
              <TextBlock Margin="2" Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="These string(s) are removed. Your user need to install Flammenwerfer Plugin v0.4.0 or later, otherwise these string(s) will not be removed and displaying original value."/>
              <WrapPanel>
                <!-- INFO: Something like ItemsRepeater for this, 1 textbox for each character. And also make it scroll-able when too much -->
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="00000000"
/>
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="0000ABCD"
  />
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="F1A88E22"
  />
              </WrapPanel>
              <!-- INFO: For newer format version in future.
              <TextBlock Margin="2" Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="These string(s) were made into barbecue. Your user need to install Flammenwerfer Plugin v0.5.0 or later, otherwise your user will be kicked out of the party."/>
              <WrapPanel>
                INFO: Something like ItemsRepeater for this, 1 textbox for each character. And also make it scroll-able when too much
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="00000000"
/>
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="0000ABCD"
  />
                <TextBox Padding="2.5" Margin="2" Width="Auto"
  BorderThickness="1"
  AutoWordSelection="False"
  VerticalScrollBarVisibility="Disabled"
  HorizontalScrollBarVisibility="Disabled"
  IsReadOnly="True"
  Text="F1A88E22"
  />
              </WrapPanel> -->
            </StackPanel>
          </Expander.Content>
        </Expander>
        <Label Width="Auto" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Label.Content>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Margin="0, 1, 5, 0" Text="&#xE946;" 
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Grid.Column="1" Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="This is an example of guiding user to download Flammenwerfer Plugin to use in your mod description. Your user do not need it if your mod passed FsLocalization Loader Plugin Compatibility test."/>
            </Grid>
          </Label.Content>
        </Label>
        <TextBox Padding="2.5" Margin="5, 2, 5, 2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
         BorderThickness="1"
         VerticalScrollBarVisibility="Auto"
         HorizontalScrollBarVisibility="Auto"
         TextWrapping="Wrap"
         IsReadOnly="True">
          [Warning] This mod contains features not supported by FsLocalizationPlugin. Strings in your game will not be displayed correctly. Please install Flammenwerfer Plugin from: https://github.com/shoushou1106/FrostyFlammenwerferPlugin
        </TextBox>
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="1" Height="38">
      <Grid Margin="5">
        <DockPanel LastChildFill="False">
          <Button x:Name="CancelButton" Padding="6, 3, 6, 3" Margin="3" DockPanel.Dock="Left" Width="Auto" Command="{Binding CancelCommand}">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <Image Margin="0, 1, 5, 0" Width="14" Source="/FrostyControls;component/Images/Clear.png"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Exit"/>
              </StackPanel>
            </Button.Content>
          </Button>

          <Button x:Name="RefreshButton" Padding="6, 3, 6, 3" Margin="3" DockPanel.Dock="Right" Width="Auto">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0, 1, 5, 0" Text="&#xE72C;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Refresh"/>
              </StackPanel>
            </Button.Content>
          </Button>
          
          <Button Padding="6, 3, 6, 3" Margin="3" DockPanel.Dock="Right" Width="Auto">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <Image Margin="0, 1, 5, 0" Width="14" Source="/FrostyCore;component/Images/Copy.png"
       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Copy Guide"/>
              </StackPanel>
            </Button.Content>
          </Button>
        </DockPanel>
      </Grid>
    </Grid>

  </Grid>
</local:FlammenwerferWindowBase>
