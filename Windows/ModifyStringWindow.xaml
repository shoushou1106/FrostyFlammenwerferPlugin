<local:FlammenwerferWindowBase x:Class="FsLocalizationPlugin.Windows.ModifyStringWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FsLocalizationPlugin.Windows"
        xmlns:core="clr-namespace:Frosty.Core;assembly=FrostyCore"
        xmlns:fdev="FrostyDeveloper"
        mc:Ignorable="d"
        UseLayoutRounding="True"
        Title="Modify String - Flammenwerfer" SizeToContent="Height" MaxHeight="850" Width="400"
        >
  <!-- View model: ViewModels/ModifyStringViewModel.cs -->

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FrostyControls;component/Themes/Generic.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Background="{StaticResource WindowBackground}">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource ListBackground}"/>
    <Grid x:Name="MainGrid" Grid.Row="0" Margin="5, 10, 5, 10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="3">
        <Label Width="Auto">
          <Label.Content>
            <StackPanel Orientation="Horizontal">
              <TextBlock Margin="0, 1, 5, 0" Text="&#xF2B7;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Language: "/>
            </StackPanel>
          </Label.Content>
        </Label>
        <ComboBox x:Name="LanguageComboBox" MinWidth="140" Width="Auto" Margin="2"
                    ItemsSource="{Binding Languages}"
                    SelectedItem="{Binding SelectedLanguage}">
        </ComboBox>
      </WrapPanel>
      <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="3">
        <Label Width="Auto">
          <Label.Content>
            <StackPanel Orientation="Horizontal">
              <Image Margin="0, 2, 5, 0" Width="14" Source="/FsLocalizationPlugin;component/Images/tag_32dp_FFFFFF_FILL0_wght600_GRAD-25_opsz24.png"
                                RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Hash or ID: "/>
            </StackPanel>
          </Label.Content>
        </Label>
        <TextBox Padding="2.5" Margin="2" Width="Auto" MinWidth="100"
                    BorderThickness="1"
                    Text="{Binding HashOrId, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    AcceptsTab="False"
                    AcceptsReturn="False"
                    AutoWordSelection="False"
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollBarVisibility="Disabled"
                    >
        </TextBox>
        <TextBox Padding="2.5" Margin="2" Width="Auto"
                    BorderThickness="1"
                    Text="{Binding IdToHash, Mode=OneWay}"
                    AcceptsTab="False"
                    AcceptsReturn="False"
                    AutoWordSelection="False"
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollBarVisibility="Disabled"
                         IsReadOnly="True"
                    >
          <TextBox.Style>
            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ShowIdToHash}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBox.Style>
        </TextBox>
      </WrapPanel>

      <Grid Grid.Row="2" Margin="3">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Width="Auto">
          <Label.Content>
            <StackPanel Orientation="Horizontal">
              <TextBlock Margin="0, 1, 5, 0" Text="&#xE7B3;"
                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                         RenderOptions.BitmapScalingMode="HighQuality"/>
              <TextBlock Foreground="{StaticResource FontColor}" Text="Current Value: "/>
              <TextBlock Foreground="{StaticResource FontColor}" FontStyle="Italic" Text="(Modified)">
                <TextBlock.Style>
                  <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsModified}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </StackPanel>
          </Label.Content>
        </Label>

        <TextBox x:Name="PreviewTextBox" Grid.Row="1" Padding="2.5" Margin="5, 2, 5, 2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                 BorderThickness="1"
                 Text="{Binding StringValue, Mode=OneWay}"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 IsReadOnly="True">
          <TextBox.Style>
            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding HasStringValue}" Value="False">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBox.Style>
        </TextBox>

        <Label x:Name="StatusLabel" Grid.Row="1" VerticalAlignment="Top">
          <Label.Style>
            <Style TargetType="{x:Type Label}">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding HasStringValue}" Value="False">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Label.Style>
          <Label.Content>
            <TextBlock Foreground="{StaticResource FontColor}" TextWrapping="Wrap" Text="{Binding StatusMessage}"/>
          </Label.Content>
        </Label>
      </Grid>

      <Grid Grid.Row="3" Margin="3">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <WrapPanel Grid.Row="0" Width="Auto">
          <Label>
            <Label.Content>
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0, 1, 5, 0" Text="&#xEC87;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="New Value: "/>
              </StackPanel>
            </Label.Content>
          </Label>
          <Button Padding="6, 3, 6, 3" Margin="0, 2, 0, 2" Width="Auto" Command="{Binding CopyAboveCommand}">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <Image Margin="0, 1, 5, 0" Width="14" Source="/FrostyCore;component/Images/Copy.png"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Copy from Above"/>
              </StackPanel>
            </Button.Content>
          </Button>
        </WrapPanel>
        <TextBox x:Name="EditTextBox" Grid.Row="1" Padding="2.5" Margin="5, 2, 5, 2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                 BorderThickness="1"
                 Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 AcceptsReturn="True" AcceptsTab="True"/>
      </Grid>
    </Grid>

    <Grid Grid.Row="1" Height="38">
      <Grid Margin="5">
        <DockPanel LastChildFill="False">
          <Button x:Name="CancelButton" Padding="6, 3, 6, 3" Margin="3" DockPanel.Dock="Left" Width="Auto" Command="{Binding CancelCommand}">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <Image Margin="0, 1, 5, 0" Width="14" Source="/FrostyControls;component/Images/Clear.png"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Exit"/>
              </StackPanel>
            </Button.Content>
          </Button>




          <Button x:Name="ModifyButton" Padding="6, 3, 6, 3" Margin="3" DockPanel.Dock="Right" Width="Auto" Command="{Binding ModifyCommand}">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0, 1, 5, 0" Text="&#xE70F;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Add / Modify"/>
              </StackPanel>
            </Button.Content>
          </Button>

          <Button x:Name="RevertButton" Padding="6, 3, 6, 3" Margin="3" DockPanel.Dock="Right" Width="Auto" Command="{Binding RevertCommand}">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <Image Margin="0, 1, 5, 0" Width="14" Source="/FrostyEditor;component/Images/Revert.png"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Revert"/>
              </StackPanel>
            </Button.Content>
          </Button>

          <Button x:Name="RemoveButton" Padding="6, 3, 6, 3" Margin="3" DockPanel.Dock="Right" Width="Auto" Command="{Binding RemoveCommand}">
            <Button.Content>
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0, 1, 5, 0" Text="&#xE75C;"
           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
           RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Foreground="{StaticResource FontColor}" Text="Remove"/>
              </StackPanel>
            </Button.Content>
          </Button>

        </DockPanel>
      </Grid>
    </Grid>

  </Grid>
</local:FlammenwerferWindowBase>
